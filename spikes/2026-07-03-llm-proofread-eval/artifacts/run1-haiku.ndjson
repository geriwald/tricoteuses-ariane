{"t": 922540, "seq": 423, "kind": "utterance", "state": "consolidated", "text": "Donc je mets aux voix le 1388 qui fait l'objet d'un scrutin public.", "source": "llm", "supersedes": 13}
{"t": 946150, "seq": 424, "kind": "utterance", "state": "consolidated", "text": "Votant 62 exprimés, 62 majorité.", "source": "llm", "supersedes": 17}
{"t": 982620, "seq": 425, "kind": "utterance", "state": "consolidated", "text": "Je vais mettre aux voix.", "source": "llm", "supersedes": 28}
{"t": 983700, "seq": 426, "kind": "utterance", "state": "consolidated", "text": "Je vais mettre aux voix cet amendement 449 qui vient de recevoir un double avis défavorable, commission, gouvernement.", "source": "llm", "supersedes": 29}
