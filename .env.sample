# Copy to .env and fill in. .env is gitignored.

# Deepgram speech-to-text API key.
# Only needed to re-run the transcription spike under spikes/ (batch + streaming).
# The four bricks (b1-b4) do not call Deepgram directly.
DEEPGRAM_API_KEY=

# --- Optional overrides for the bricks (sensible defaults if unset) ---

# B2 (replay): default capture bundle when --record is omitted.
# Example with the bundled local captures:
# ARIANE_RECORD=data/2026-07-02-matin

# B1 (weaver): path to your clone of whisper_streaming (ufal/whisper_streaming).
# Default: ~/code/whisper-live/whisper_streaming
# WHISPER_STREAMING_PATH=

# B3 (capture): executable that reads a message on stdin and pushes a
# notification (e.g. Telegram) when a sitting opens/closes. Unset = no notify.
# NOTIFY_SEND=
